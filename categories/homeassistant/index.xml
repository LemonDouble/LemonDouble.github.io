&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="n">turn_on&lt;/span> &lt;span class="p">(&lt;/span>&lt;span class="n">화장실_등&lt;/span>&lt;span class="p">)&lt;/span>
