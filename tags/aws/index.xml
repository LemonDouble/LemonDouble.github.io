&lt;p>&lt;img src="https://lemondouble.github.io/p/aws-sso%EB%A1%9C-%ED%9A%8C%EC%82%AC%EC%97%90%EC%84%9C-%EB%B3%B4%EB%8D%98-%EA%B7%B8-%ED%99%94%EB%A9%B4-%EC%A7%91%EC%97%90%EC%84%9C%EB%8F%84-%EC%93%B0%EA%B8%B0-%EB%AC%B4%EB%A3%8C/2023-01-22-01-37-55.png"
